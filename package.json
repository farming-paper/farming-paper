{
  "name": "farming-paper",
  "version": "0.0.1",
  "description": "문제를 직접 디자인하고 최적화된 루틴으로 출제되는 문제를 풀어보세요.",
  "main": "index.js",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "start": "remix-serve ./build/index.js",
    "build": "remix build --sourcemap && prisma generate",
    "format": "prettier --write .",
    "dev": "remix dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "type-check": "tsc --noEmit",
    "gen:sb": "supabase status && cat app/supabase/typegen-prefix.txt > app/supabase/generated/supabase-types.ts && supabase gen types typescript --local >> app/supabase/generated/supabase-types.ts && prettier --write app/supabase/generated/supabase-types.ts",
    "gen:prisma": "prisma generate",
    "gen": "concurrently --names js -c bgBlue.bold 'pnpm gen:sb'",
    "sb-diff": "supabase db diff --use-migra -f",
    "sb-push": "supabase db push"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@floating-ui/react": "^0.26.9",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.3",
    "@nextui-org/react": "^2.2.10",
    "@prisma/client": "^5.11.0",
    "@rehookify/datepicker": "^6.6.1",
    "@remix-run/css-bundle": "^2.8.1",
    "@remix-run/node": "^2.8.1",
    "@remix-run/react": "^2.8.1",
    "@remix-run/serve": "^2.8.1",
    "@remix-run/server-runtime": "^2.8.1",
    "@remix-validated-form/with-zod": "^2.0.7",
    "@supabase/auth-helpers-remix": "^0.3.0",
    "@supabase/supabase-js": "^2.39.8",
    "@tailwindcss/forms": "^0.5.7",
    "@toss/hangul": "^1.6.1",
    "@vercel/analytics": "^1.2.2",
    "@vercel/remix": "^2.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "antd": "^5.15.3",
    "compromise": "^14.12.0",
    "dayjs": "^1.11.10",
    "framer-motion": "^11.0.20",
    "jotai": "^2.7.1",
    "katex": "^0.16.10",
    "lru-cache": "^10.2.0",
    "lucide-react": "^0.363.0",
    "marked": "^12.0.1",
    "nanoid": "^5.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.1",
    "react-select": "^5.8.0",
    "remix-validated-form": "^5.1.5",
    "rfdc": "^1.3.1",
    "tailwind-merge": "^2.2.2",
    "type-fest": "^4.14.0",
    "usehooks-ts": "^3.0.2",
    "vite": "^5.0.10",
    "vite-node": "^1.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.3",
    "@remix-run/dev": "^2.8.1",
    "@remix-run/eslint-config": "^2.8.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.69",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "happy-dom": "^14.3.6",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "prisma": "^5.11.0",
    "react-router-dom": "^6.22.3",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
